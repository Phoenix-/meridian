<Window
    x:Class="Meridian.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Meridian"
    xmlns:auth="using:Meridian.Auth"
    xmlns:vm="using:Meridian.ViewModels"
    Title="Meridian">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top bar / custom title bar -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Background="Transparent" Padding="0,8"
              Loaded="OnTitleBarLoaded" SizeChanged="OnTitleBarSizeChanged">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- View buttons -->
            <StackPanel x:Name="LeftButtons" Grid.Column="0" Orientation="Horizontal" Spacing="4"
                        SizeChanged="OnTitleBarSizeChanged">
                <Button x:Name="BtnDay" Content="День" Click="OnDayClick"
                        AutomationProperties.AutomationId="BtnDay"/>
                <Button x:Name="BtnWeek" Content="Неделя" Click="OnWeekClick"
                        AutomationProperties.AutomationId="BtnWeek"/>
                <Button x:Name="BtnMonth" Content="Месяц" Click="OnMonthClick"
                        AutomationProperties.AutomationId="BtnMonth"/>
            </StackPanel>

            <!-- Date label -->
            <TextBlock Grid.Column="1" x:Name="DateLabel"
                       AutomationProperties.AutomationId="DateLabel"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Style="{StaticResource SubtitleTextBlockStyle}"/>

            <!-- Right controls -->
            <StackPanel x:Name="RightButtons" Grid.Column="2" Orientation="Horizontal" Spacing="4"
                        SizeChanged="OnTitleBarSizeChanged">
                <Button Content="&#xE76B;" FontFamily="Segoe MDL2 Assets" Click="OnPrevClick" ToolTipService.ToolTip="Назад"/>
                <Button Content="Сегодня" Click="OnTodayClick" ToolTipService.ToolTip="Перейти к сегодня"/>
                <Button Content="&#xE76C;" FontFamily="Segoe MDL2 Assets" Click="OnNextClick" ToolTipService.ToolTip="Вперёд"/>
                <Button x:Name="BtnRefresh" Click="OnRefreshClick" ToolTipService.ToolTip="Обновить">
                    <Grid Width="16" Height="16">
                        <TextBlock x:Name="RefreshIcon" Text="&#xE72C;" FontFamily="Segoe MDL2 Assets"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14"/>
                        <ProgressRing x:Name="RefreshRing" IsActive="False" Width="16" Height="16"/>
                    </Grid>
                </Button>
                <Button x:Name="BtnTestToast" Content="&#xEA8F;" FontFamily="Segoe MDL2 Assets"
                        Click="OnTestToastClick" Visibility="Collapsed"
                        ToolTipService.ToolTip="Тестовый тост через 3 секунды (Show)"/>
                <Button x:Name="BtnTestScheduled" Content="&#xE823;" FontFamily="Segoe MDL2 Assets"
                        Click="OnTestScheduledClick" Visibility="Collapsed"
                        ToolTipService.ToolTip="Тестовый отложенный тост через 30 секунд (AddToSchedule)"/>
                <Button x:Name="BtnSettings" Content="&#xE713;" FontFamily="Segoe MDL2 Assets"
                        Click="OnSettingsClick" ToolTipService.ToolTip="Настройки"/>
                <Button x:Name="BtnAccounts"
                        ToolTipService.ToolTip="Аккаунты">
                    <Grid>
                        <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets"/>
                        <!-- "!" badge: visible when at least one account has an expired session. -->
                        <Border x:Name="AccountsBadge" Visibility="Collapsed"
                                Width="10" Height="10" CornerRadius="5"
                                Background="{StaticResource AppErrorBrush}"
                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                Margin="0,-2,-2,0">
                            <TextBlock Text="!" Foreground="White" FontSize="8" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Margin="0,-1,0,0"/>
                        </Border>
                    </Grid>
                    <Button.Flyout>
                        <Flyout x:Name="AccountsFlyout" Placement="Bottom">
                            <StackPanel Spacing="8" MinWidth="260">
                                <TextBlock Text="Аккаунты" Style="{StaticResource SubtitleTextBlockStyle}"/>
                                <ItemsControl x:Name="AccountsList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:AccountRow">
                                            <Grid Margin="0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{x:Bind Email}"
                                                           VerticalAlignment="Center" TextWrapping="NoWrap"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <!-- Warning icon: click to re-auth. Only visible when token is bad. -->
                                                <Button Grid.Column="1" Content="&#xE7BA;" FontFamily="Segoe MDL2 Assets"
                                                        Margin="8,0,0,0" Tag="{x:Bind Id}"
                                                        Foreground="{StaticResource AppErrorBrush}"
                                                        Visibility="{x:Bind IsExpired, Mode=OneWay}"
                                                        Click="OnReauthAccountClick"
                                                        ToolTipService.ToolTip="Сессия истекла — войдите снова"/>
                                                <Button Grid.Column="2" Content="&#xE74D;" FontFamily="Segoe MDL2 Assets"
                                                        Margin="8,0,0,0" Tag="{x:Bind Id}"
                                                        Click="OnRemoveAccountClick"
                                                        ToolTipService.ToolTip="Удалить аккаунт"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Button Content="+ Добавить аккаунт" Click="OnAddAccountClick"
                                        HorizontalAlignment="Stretch"/>
                            </StackPanel>
                        </Flyout>
                    </Button.Flyout>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Content frame -->
        <Frame Grid.Row="1" x:Name="ContentFrame"/>
    </Grid>
</Window>
