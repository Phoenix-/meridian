<Window
    x:Class="Meridian.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Meridian"
    Title="Meridian">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top bar / custom title bar -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}" Padding="0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- View buttons -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4">
                <Button x:Name="BtnDay" Content="День" Click="OnDayClick"/>
                <Button x:Name="BtnWeek" Content="Неделя" Click="OnWeekClick"/>
                <Button x:Name="BtnMonth" Content="Месяц" Click="OnMonthClick"/>
            </StackPanel>

            <!-- Date label -->
            <TextBlock Grid.Column="1" x:Name="DateLabel"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Style="{StaticResource SubtitleTextBlockStyle}"/>

            <!-- Right controls -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
                <Button Content="&#xE76B;" FontFamily="Segoe MDL2 Assets" Click="OnPrevClick" ToolTipService.ToolTip="Назад"/>
                <Button Content="&#xE76C;" FontFamily="Segoe MDL2 Assets" Click="OnNextClick" ToolTipService.ToolTip="Вперёд"/>
                <Button Content="&#xE72C;" FontFamily="Segoe MDL2 Assets" Click="OnRefreshClick" ToolTipService.ToolTip="Обновить"/>
                <Button x:Name="BtnAccounts" Content="&#xE77B;" FontFamily="Segoe MDL2 Assets"
                        ToolTipService.ToolTip="Аккаунты">
                    <Button.Flyout>
                        <Flyout x:Name="AccountsFlyout" Placement="Bottom">
                            <StackPanel Spacing="8" MinWidth="220">
                                <TextBlock Text="Аккаунты" Style="{StaticResource SubtitleTextBlockStyle}"/>
                                <ItemsControl x:Name="AccountsList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding}"
                                                           VerticalAlignment="Center" TextWrapping="NoWrap"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <Button Grid.Column="1" Content="&#xE74D;" FontFamily="Segoe MDL2 Assets"
                                                        Margin="8,0,0,0" Tag="{Binding}"
                                                        Click="OnRemoveAccountClick"
                                                        ToolTipService.ToolTip="Удалить аккаунт"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Button Content="+ Добавить аккаунт" Click="OnAddAccountClick"
                                        HorizontalAlignment="Stretch"/>
                            </StackPanel>
                        </Flyout>
                    </Button.Flyout>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Content frame -->
        <Frame Grid.Row="1" x:Name="ContentFrame"/>
    </Grid>
</Window>
