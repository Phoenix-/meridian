<UserControl
    x:Class="Meridian.Views.EventDetailsFlyout"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    MaxWidth="420">
    <Grid ColumnSpacing="10" Padding="2">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Calendar color stripe -->
        <Border Grid.Column="0"
                x:Name="ColorStripe"
                CornerRadius="2"
                VerticalAlignment="Stretch"/>

        <StackPanel Grid.Column="1" Spacing="8">
            <TextBlock x:Name="TitleText"
                       FontSize="18"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap"
                       IsTextSelectionEnabled="True"/>

            <TextBlock x:Name="TimeText"
                       FontSize="13"
                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                       TextWrapping="Wrap"
                       IsTextSelectionEnabled="True"/>

            <StackPanel x:Name="CalendarRow"
                        Orientation="Horizontal"
                        Spacing="6">
                <Ellipse x:Name="CalendarDot"
                         Width="10" Height="10"
                         VerticalAlignment="Center"/>
                <TextBlock x:Name="CalendarText"
                           FontSize="12"
                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                           IsTextSelectionEnabled="True"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
            </StackPanel>

            <!-- RSVP row: shown only when the user is an attendee on a writable
                 calendar. Toggle buttons reflect the current responseStatus. -->
            <StackPanel x:Name="RsvpStack"
                        Spacing="4"
                        Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <ToggleButton x:Name="RsvpYes"
                                  Content="Да"
                                  MinWidth="60"
                                  Click="OnRsvpYesClick"/>
                    <ToggleButton x:Name="RsvpNo"
                                  Content="Нет"
                                  MinWidth="60"
                                  Click="OnRsvpNoClick"/>
                    <ToggleButton x:Name="RsvpMaybe"
                                  Content="Возможно"
                                  MinWidth="80"
                                  Click="OnRsvpMaybeClick"/>
                </StackPanel>
                <TextBlock x:Name="RsvpError"
                           FontSize="12"
                           Foreground="#C62828"
                           Visibility="Collapsed"
                           Text="Не удалось сохранить ответ"/>
            </StackPanel>

            <ScrollViewer x:Name="DescriptionScroll"
                          MaxHeight="180"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Visibility="Collapsed">
                <TextBlock x:Name="DescriptionText"
                           FontSize="13"
                           TextWrapping="Wrap"
                           IsTextSelectionEnabled="True"/>
            </ScrollViewer>

            <StackPanel x:Name="MeetStack"
                        Spacing="0"
                        Visibility="Collapsed"/>

            <StackPanel x:Name="LocationStack"
                        Orientation="Horizontal"
                        Spacing="8"
                        Visibility="Collapsed"/>

            <StackPanel x:Name="GuestsStack"
                        Spacing="4"
                        Visibility="Collapsed"/>

            <StackPanel x:Name="RoomsStack"
                        Spacing="4"
                        Visibility="Collapsed"/>

            <StackPanel x:Name="RemindersStack"
                        Spacing="2"
                        Visibility="Collapsed"/>

            <HyperlinkButton x:Name="OpenInGoogleButton"
                             Content="Открыть в Google Calendar"
                             Padding="0,4,0,0"
                             Click="OnOpenInGoogleClick"/>
        </StackPanel>
    </Grid>
</UserControl>
