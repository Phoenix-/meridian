<UserControl
    x:Class="Meridian.Views.WeekRowControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Layout (built in code-behind):
          Row 0 (Auto) — DayCellControl date circles, one per column
          Row 1 (Star) — per-column DayCellControl.BodyPanel (band-reserve spacer + chips),
                         plus a 7-column band overlay Grid on top that draws the continuous
                         multi-day bands. Each day reserves only its own band height; the
                         overlay positions bands at lane*laneHeight so they stay straight.
    -->
    <Grid x:Name="WeekGrid"/>

</UserControl>
