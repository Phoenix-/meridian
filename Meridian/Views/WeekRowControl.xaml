<UserControl
    x:Class="Meridian.Views.WeekRowControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Layout (built in code-behind):
          Row 0 (Auto)    — DayCellControl date circles, one per column
          Row 1..N (Auto) — span band lanes, one row per lane
          Row N+1 (Star)  — DayCellControl chip stacks, one per column
    -->
    <Grid x:Name="WeekGrid"/>

</UserControl>
