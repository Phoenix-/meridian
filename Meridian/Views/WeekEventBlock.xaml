<UserControl
    x:Class="Meridian.Views.WeekEventBlock"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border x:Name="Root"
            CornerRadius="4"
            Padding="4,2,4,2"
            BorderThickness="2">
        <StackPanel x:Name="ContentStack" Spacing="0">
            <TextBlock x:Name="TitleText"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="White"
                       TextTrimming="CharacterEllipsis"
                       TextWrapping="NoWrap"/>
            <TextBlock x:Name="TimeText"
                       FontSize="10"
                       TextTrimming="CharacterEllipsis"
                       Visibility="Collapsed"/>
        </StackPanel>
    </Border>
</UserControl>
