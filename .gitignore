# Build output
bin/
obj/

# User-specific VS files
*.user
*.suo
.vs/

# C# DevKit / Roslyn LSP cache (regenerated by VS Code)
*.lscache

# Secrets — never commit
client_secret.json
Meridian/Auth/Secrets.g.cs

# Claude Code: share agent definitions, keep user-specific settings local
.claude/*
!.claude/agents/

# NuGet
*.nupkg
packages/

# UI test artifacts
Meridian.UiTests/TestResults/

# MSIX packaging build artifacts (staged payload, .msix, dev cert, unpack).
# The generated PNG assets under Meridian/Assets/msix/ ARE committed.
packaging/out/

# OS
Thumbs.db
Desktop.ini
